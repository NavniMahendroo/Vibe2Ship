# Drift Backend Configuration

# Database Connection URL (SQLite is used by default for local development)
DATABASE_URL=sqlite:///./drift.db
# For PostgreSQL (local Docker compose): DATABASE_URL=postgresql://drift:drift@db:5432/drift
# Note: In production (e.g. Railway), DATABASE_URL is auto-provisioned by the database service.

# JWT Authentication Config
JWT_SECRET_KEY=supersecretkeychangeinproduction1234567890abcdef
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Gemini API Key (Required for Smart Extension Coach & Voice transcription)
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
