# Drift Backend Configuration

# Database Connection URL (SQLite is used if postgresql is not configured)
DATABASE_URL=sqlite:///./drift.db
# For PostgreSQL: postgresql://postgres:postgres@localhost:5432/drift

# JWT Authentication Config
JWT_SECRET_KEY=supersecretkeychangeinproduction1234567890abcdef
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Gemini API Key (Required for Smart Extension Coach & Voice transcription)
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=AQ.Ab8RN6K0EquvjRj0LeTPtqG-a9k-HVoZzgQREoD93dFQ2YxcHw
